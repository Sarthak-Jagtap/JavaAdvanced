package Questions;

import java.util.LinkedHashMap;
import java.util.Map;

/**
 * Problem Statement 1–
 * 
 * You’re given an array of integers, print the number of times each integer has
 * occurred in the array.
 * 
 * Example
 * 
 * Input :
 * 
 * 10
 * 
 * 1 2 3 3 4 1 4 5 1 2
 * 
 * Output :
 * 
 * 1 occurs 3 times
 * 
 * 2 occurs 2 times
 * 
 * 3 occurs 2 times
 * 
 * 4 occurs 2 times
 * 
 * 5 occurs 1 times
 * 
 */
public class Ques01 {

	public static void elemenentOccurance(int arr[]) {
		int n = arr.length;

		Map<Integer, Integer> map = new LinkedHashMap<>();

		for (int i = 0; i < n; i++) {
			map.put(arr[i], map.getOrDefault(arr[i], 0) + 1);
		}

		for (Map.Entry<Integer, Integer> temp : map.entrySet()) {
			System.out.println("" + temp.getKey() + " occurs " + temp.getValue() + " times");
		}
	}

	public static void main(String[] args) {
		int arr[] = { 1, 2, 3, 3, 4, 1, 4, 5, 1, 2 };
		
		elemenentOccurance(arr);
	}
}
