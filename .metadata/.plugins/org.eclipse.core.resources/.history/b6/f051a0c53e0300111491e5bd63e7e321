package HackerRankM1;

/**
 * Given an array of integers, calculate the sum of all factors of each number
 * and return an array containing the corresponding sums.
 */

public class Ques02 {

	private int fact(int num) {
		if (num == 1)
			return 1;

		int sum = num + 1;
		for (int i = 2; i * i <= num; i++) {
			if (num % i == 0) {
				sum += i;
				if (i * i != num)
					sum += num / i;
			}
		}

		return sum;
	}

	public int factSum(int arr[]) {
		int n = arr.length;
		int sum = 0;
		for (int i = 0; i < n; i++) {
			sum += fact(arr[i]);
		}
		return sum;
	}

	public static void main(String[] args) {
		int arr[] = { 16 };
		Ques02 obj = new Ques02();
		System.out.println(obj.factSum(arr));
	}
}
