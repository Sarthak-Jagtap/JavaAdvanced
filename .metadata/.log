package LeetCode;

import java.util.Scanner;

/**
 * 📌 Longest Substring with K Distinct Characters
 * 
 * 🧩 Problem Statement
 * 
 * Given a string S and an integer K, find the length of the longest substring
 * of S that contains exactly K distinct characters.
 * 
 * A substring is a contiguous sequence of characters within a string.
 * 
 * 🎯 Output
 * 
 * Return an integer denoting the length of the longest substring with exactly K
 * distinct characters.
 * 
 * If no such substring exists, return -1.
 * 
 */

public class SubString1 {
	
	public static HashMap<Characher, Integer> map = new 
	
	public static boolean reqSuString(String subString) {
		
		
		return true;
	}
	
	public static void fillHashMap(String str) {
		
	}
	
	public static int longestSubString(String str,int k) {
		
		
		
		int n = str.length();
		for(int i = 0; i<n; i ++ ) {
			for(int j = i + k; j < n + 1; j++) {
				String subStr = str.substring(i, j);
				System.out.println(subStr);
			}
		}
		
		return -1;
	}

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		String input = sc.next();
		
		int k = sc.nextInt();
		
		longestSubString(input, k);
		

	}

}

